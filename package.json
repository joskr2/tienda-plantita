{
  "name": "chini",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios --device 'iPhone 17'",
    "start": "expo start",
    "prebuild": "expo prebuild",
    "lint": "biome check .",
    "format": "biome check --write . && pnpm run format:tailwind",
    "format:tailwind": "tailwind-class-sort --dir app && tailwind-class-sort --dir components",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo/metro-runtime": "^55.0.6",
    "@expo/ui": "^55.0.3",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.6",
    "@supabase/supabase-js": "^2.38.4",
    "expo": "~55.0.0",
    "expo-constants": "~55.0.8",
    "expo-dev-client": "~55.0.17",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.6",
    "expo-secure-store": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.10",
    "expo-web-browser": "~55.0.10",
    "nativewind": "latest",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@biomejs/biome": "^2.4.8",
    "@kettle4ot/tailwind-class-sort": "^1.0.2",
    "@types/react": "~19.2.14",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
